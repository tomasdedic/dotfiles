{
  "lastChangelogVersion": "0.79.1",
  "defaultProvider": "github-copilot",
  "theme": "light",
  "defaultModel": "claude-opus-4.8",
  "defaultThinkingLevel": "high",
  "enabledModels": [
    "github-copilot/gpt-5.3-codex",
    "github-copilot/gemini-3.1-pro-preview",
    "github-copilot/claude-sonnet-4.6",
    "github-copilot/claude-sonnet-4.5"
  ],
  "hideThinkingBlock": true,
  "packages": [
    "packages/pi-amplike",
    "packages/pi-sub/packages/sub-core",
    "packages/pi-sub/packages/sub-bar",
    "~/GIT/AI/pi-side-agents",
    "packages/chrome-cdp-skill",
    "packages/pi-k8s-ctx",
    "npm:pi-simplify",
    "npm:pi-slopchop",
    "npm:pi-memory-md",
    "npm:pi-boomerang"
  ],
  "extensions": [
    "extensions/tps.ts"
  ],
  "claudeAgentSdkProvider": {
    "overrideSystemPrompt": true
  },
  "quietStartup": true,
  "pi-memory-md": {
    "memoryDir": {
      "repoUrl": "https://github.com/tomasdedic/pimem.git",
      "localPath": "~/.pi/memory-md",
      "globalMemory": "global"
    }
  }
}